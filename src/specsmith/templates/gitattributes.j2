# Auto-detect text files and normalize line endings
* text=auto

# Common text files
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.xml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.psm1 text eol=crlf
{% if project.type in ('cli-python', 'library-python', 'backend-frontend', 'backend-frontend-tray', 'data-ml') %}

# Python
*.py text eol=lf
*.pyi text eol=lf
*.pyx text eol=lf
{% endif %}
{% if project.type in ('cli-rust', 'library-rust') %}

# Rust
*.rs text eol=lf
Cargo.lock text -diff linguist-generated
{% endif %}
{% if project.type in ('cli-go',) %}

# Go
*.go text eol=lf
go.sum text -diff linguist-generated
{% endif %}
{% if project.type in ('cli-c', 'library-c', 'embedded-hardware') %}

# C / C++
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.o binary
*.a binary
*.so binary
*.dll binary
{% endif %}
{% if project.type in ('web-frontend', 'fullstack-js', 'browser-extension', 'monorepo') %}

# JavaScript / TypeScript
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
package-lock.json text -diff linguist-generated
yarn.lock text -diff linguist-generated
pnpm-lock.yaml text -diff linguist-generated
{% endif %}
{% if project.type == 'dotnet-app' %}

# .NET
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=crlf
*.dll binary
*.exe binary
{% endif %}
{% if project.type == 'fpga-rtl' %}

# FPGA / RTL
*.vhd text eol=lf
*.vhdl text eol=lf
*.v text eol=lf
*.sv text eol=lf
*.xdc text eol=lf
*.sdc text eol=lf
*.tcl text eol=lf
*.bit binary
*.bin binary
*.xsa binary
*.ltx binary
*.mmi binary
{% endif %}
{% if project.type in ('yocto-bsp',) %}

# Yocto / BitBake
*.bb text eol=lf
*.bbappend text eol=lf
*.bbclass text eol=lf
*.conf text eol=lf
*.dts text eol=lf
*.dtsi text eol=lf
{% endif %}
{% if project.type == 'pcb-hardware' %}

# KiCad / PCB
*.kicad_pcb binary diff
*.kicad_sch binary diff
*.kicad_pro text eol=lf
*.step binary
*.wrl binary
{% endif %}
{% if project.type == 'research-paper' %}

# LaTeX
*.tex text eol=lf
*.bib text eol=lf
*.cls text eol=lf
*.sty text eol=lf
*.pdf binary
*.eps binary
{% endif %}
{% if project.type == 'api-specification' %}

# API / Protobuf
*.proto text eol=lf
*.graphql text eol=lf
{% endif %}
{% if project.type == 'mobile-app' %}

# Mobile
*.swift text eol=lf
*.kt text eol=lf
*.dart text eol=lf
*.apk binary
*.aab binary
*.ipa binary
{% endif %}
{% if project.type == 'devops-iac' %}

# Terraform / IaC
*.tf text eol=lf
*.tfvars text eol=lf
*.hcl text eol=lf
{% endif %}
