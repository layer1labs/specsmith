[build-system]
requires = ["setuptools>=68.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project.name }}"
version = "0.1.0"
description = "{{ project.description if project.description else project.type_label + ' — scaffold only.' }}"
requires-python = ">=3.10"
license = {text = "MIT"}
{% if project.type == 'cli-python' %}

[project.scripts]
{{ project.package_name }} = "{{ project.package_name }}.cli:main"
{% endif %}

[project.optional-dependencies]
dev = [
    "pytest>=7.0",
    "ruff>=0.4",
    "watchdog>=4.0",  # specsmith watch — native filesystem events
]

[tool.setuptools.packages.find]
where = ["src"]
