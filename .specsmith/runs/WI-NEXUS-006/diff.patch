+                ),
+                entry_type="cleanup",
+                author="specsmith",
+                reqs="REQ-077,REQ-078,REQ-079,REQ-080",
+            )
+        except Exception:  # noqa: BLE001
+            pass  # Ledger writing is best-effort here
