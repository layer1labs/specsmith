{"seq": 740, "ts": "2026-05-17T12:36:42Z", "op": "upsert", "record_id": "REQ-206", "record": {"id": "REQ-206", "kind": "requirement", "status": "active", "label": "Tamper-Evident Agent Action Log", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-206", "title": "Tamper-Evident Agent Action Log", "description": "specsmith MUST maintain a tamper-evident, append-only agent action log capturing every governance decision, tool invocation, input, and output. The log chain MUST use SHA-256 chaining so any modification is detectable. Satisfies EU AI Act Art. 12 (logging obligations) and NIST AI RMF (GO-6).", "source": "BTWS-2027 AI Governance Report [REG-001]", "status": "implemented"}}, "prev_hash": "73cc8bc0749b476b6e8f1f6faa6f5bf7d0356c9d3005771700d23f8e8299c0c3", "hash": "d005fbfd2a817106394f3fd9a1e1dc1e14104e28db256885f81cfaee988ff2e5", "recursion_depth": 0}
{"seq": 741, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-207", "record": {"id": "REQ-207", "kind": "requirement", "status": "active", "label": "Explanation Artifacts for Governance Decisions", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-207", "title": "Explanation Artifacts for Governance Decisions", "description": "Every governance decision (preflight, verify, classify) MUST produce an 'explanation artifact' recording: what data was used, which requirements were matched, why the decision was reached, and the confidence score. Satisfies EU AI Act Art. 13 (transparency), CFPB adverse-action requirements.", "source": "BTWS-2027 AI Governance Report [REG-002]", "status": "implemented"}}, "prev_hash": "d005fbfd2a817106394f3fd9a1e1dc1e14104e28db256885f81cfaee988ff2e5", "hash": "30f9fc9cef6a94fefbc62c78a56518ff7972d24781764866fd23b1dfaf4b7403", "recursion_depth": 0}
{"seq": 742, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-208", "record": {"id": "REQ-208", "kind": "requirement", "status": "active", "label": "Action Log Replay and Export", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-208", "title": "Action Log Replay and Export", "description": "specsmith MUST support structured replay and export of agent action logs for external audit, regulatory submission, or incident investigation. Export format MUST be machine-readable (JSONL) and human-readable (Markdown). Satisfies OMB M-24-10 (AI use case inventories) and EU AI Act post-market monitoring.", "source": "BTWS-2027 AI Governance Report [REG-003]", "status": "implemented"}}, "prev_hash": "30f9fc9cef6a94fefbc62c78a56518ff7972d24781764866fd23b1dfaf4b7403", "hash": "e62db97172378d5d14e4aaf3aae6a4c282659cfdb3a4b3784e71556efb00072a", "recursion_depth": 0}
{"seq": 743, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-209", "record": {"id": "REQ-209", "kind": "requirement", "status": "active", "label": "Human Escalation Threshold", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-209", "title": "Human Escalation Threshold", "description": "specsmith MUST provide a configurable human-escalation threshold. When preflight confidence is below the threshold, or when a destructive/release intent is detected, execution MUST pause and route to human review. Satisfies NIST AI RMF (GO-4), OMB M-24-10 human-in-the-loop requirements.", "source": "BTWS-2027 AI Governance Report [REG-004]", "status": "implemented"}}, "prev_hash": "e62db97172378d5d14e4aaf3aae6a4c282659cfdb3a4b3784e71556efb00072a", "hash": "c32a19fb73656dbb8e362c7e7d89adb2941d77f22f6ac667505e6fa1f16e1075", "recursion_depth": 0}
{"seq": 744, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-210", "record": {"id": "REQ-210", "kind": "requirement", "status": "active", "label": "Emergency Kill-Switch and Circuit-Breaker", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-210", "title": "Emergency Kill-Switch and Circuit-Breaker", "description": "specsmith MUST implement an emergency kill-switch that immediately halts agent activity when: (a) the user invokes a stop command, (b) an anomaly detector triggers, or (c) the retry budget is exhausted. The kill-switch MUST be reachable from both the CLI and the REST API. Satisfies EU AI Act Art. 14 (human oversight), NIST AI RMF.", "source": "BTWS-2027 AI Governance Report [REG-005]", "status": "implemented"}}, "prev_hash": "c32a19fb73656dbb8e362c7e7d89adb2941d77f22f6ac667505e6fa1f16e1075", "hash": "cf7de4045b95f2c449754ab025ec5e8f8a48f528b23e8ac2e25eed445213bb16", "recursion_depth": 0}
{"seq": 745, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-211", "record": {"id": "REQ-211", "kind": "requirement", "status": "active", "label": "Post-Market Behavioral Monitoring and Alerting", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-211", "title": "Post-Market Behavioral Monitoring and Alerting", "description": "specsmith MUST monitor agent behavior across sessions and alert when anomalous patterns are detected: unexpected confidence regression, unusual tool usage rates, or systematic requirement mismatches. Satisfies EU AI Act Art. 72 (post-market monitoring) and OMB M-24-10.", "source": "BTWS-2027 AI Governance Report [REG-006]", "status": "implemented"}}, "prev_hash": "cf7de4045b95f2c449754ab025ec5e8f8a48f528b23e8ac2e25eed445213bb16", "hash": "75dac3879ec04b3a16baa62006a23b995f62d57be9baa7ecf422c89ce207b4fc", "recursion_depth": 0}
{"seq": 746, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-212", "record": {"id": "REQ-212", "kind": "requirement", "status": "active", "label": "One-Click Rollback for File-Modifying Actions", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-212", "title": "One-Click Rollback for File-Modifying Actions", "description": "Every agent action that modifies governance files MUST create a timestamped backup before overwriting, and MUST expose a rollback command that restores the pre-action state. Satisfies NIST AI GenAI Profile (rollback and compensation), CFPB.", "source": "BTWS-2027 AI Governance Report [REG-007]", "status": "implemented"}}, "prev_hash": "75dac3879ec04b3a16baa62006a23b995f62d57be9baa7ecf422c89ce207b4fc", "hash": "0edcd726666800f0dcab496cd276c6c91aa98bfac14360141cbec2a5aac0f443", "recursion_depth": 0}
{"seq": 747, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-213", "record": {"id": "REQ-213", "kind": "requirement", "status": "active", "label": "Safe Append-Only Write for New Governance Entries", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-213", "title": "Safe Append-Only Write for New Governance Entries", "description": "All new entries appended to governance files (LEDGER.md, REQUIREMENTS.md, TESTS.md) MUST use append-only mode — never truncating or overwriting existing content. Protects against data loss from agent errors. Satisfies EU AI Act technical controls and data integrity requirements.", "source": "BTWS-2027 AI Governance Report [REG-008]", "status": "implemented"}}, "prev_hash": "0edcd726666800f0dcab496cd276c6c91aa98bfac14360141cbec2a5aac0f443", "hash": "011ea1b2886f6a923e4d3ab2b9aca2ac8d5e43701c3a3fb63ea4a9268827df7e", "recursion_depth": 0}
{"seq": 748, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-214", "record": {"id": "REQ-214", "kind": "requirement", "status": "active", "label": "AI Disclosure Metadata in Agent Outputs", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-214", "title": "AI Disclosure Metadata in Agent Outputs", "description": "Outputs generated by specsmith agents MUST include AI disclosure metadata when surfaced to end-users: which model was used, provider, confidence level, and whether the output was governance-gated. Satisfies FTC Operation AI Comply, Utah SB149 (2024) disclosure requirements.", "source": "BTWS-2027 AI Governance Report [REG-009]", "status": "implemented"}}, "prev_hash": "011ea1b2886f6a923e4d3ab2b9aca2ac8d5e43701c3a3fb63ea4a9268827df7e", "hash": "407b8fcc241e48f6dd8fac4a97b5c552fe4d92f39ff91ab0dd4bb79d86bbcd55", "recursion_depth": 0}
{"seq": 749, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-215", "record": {"id": "REQ-215", "kind": "requirement", "status": "active", "label": "Regulatory Compliance Export Report", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-215", "title": "Regulatory Compliance Export Report", "description": "specsmith MUST generate a structured compliance export report covering: AI system inventory, risk classification, human oversight controls, audit log summary, and incident history. Satisfies OMB M-24-10, Colorado SB24-205 impact assessments, EU AI Act technical docs.", "source": "BTWS-2027 AI Governance Report [REG-010]", "status": "implemented"}}, "prev_hash": "407b8fcc241e48f6dd8fac4a97b5c552fe4d92f39ff91ab0dd4bb79d86bbcd55", "hash": "6e5ba036689d74d287c6adbd520d4460cdfdacc877b08d28ab7906affba80d07", "recursion_depth": 0}
{"seq": 750, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-216", "record": {"id": "REQ-216", "kind": "requirement", "status": "active", "label": "Agent Risk Classification Before Deployment", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-216", "title": "Agent Risk Classification Before Deployment", "description": "Before activating a governance profile or agent session, specsmith MUST classify the intended use case against EU AI Act risk tiers (prohibited, high-risk Annex III, GPAI systemic-risk, or minimal-risk). High-risk use cases MUST require additional confirmation. Satisfies EU AI Act Art. 6 risk-based approach.", "source": "BTWS-2027 AI Governance Report [REG-011]", "status": "implemented"}}, "prev_hash": "6e5ba036689d74d287c6adbd520d4460cdfdacc877b08d28ab7906affba80d07", "hash": "0ef9b3d1e67778a0509b89510da1a88db888e1db90c667173b59fccbf5b50e99", "recursion_depth": 0}
{"seq": 751, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-217", "record": {"id": "REQ-217", "kind": "requirement", "status": "active", "label": "Least-Privilege Agent Permissions", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-217", "title": "Least-Privilege Agent Permissions", "description": "Every agent session MUST operate with the minimum permissions required. Agent capabilities MUST be explicitly declared, and sensitive operations (commit, push, create PR, external calls) MUST be individually gated. Satisfies EU AI Act agent registration, NIST AI RMF least-privilege principle.", "source": "BTWS-2027 AI Governance Report [REG-012]", "status": "implemented"}}, "prev_hash": "0ef9b3d1e67778a0509b89510da1a88db888e1db90c667173b59fccbf5b50e99", "hash": "48685045d0a14037b2be722b17a2083d810eac6da17e00feb5523b4428ec395e", "recursion_depth": 0}
{"seq": 752, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-218", "record": {"id": "REQ-218", "kind": "requirement", "status": "active", "label": "Self-Optimization Bounded by Iteration Budget", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-218", "title": "Self-Optimization Bounded by Iteration Budget", "description": "All self-improvement loops (agent improve, eval harness, continuous learning) MUST be bounded by a configurable iteration budget. Unbounded recursion or runaway optimisation MUST be prevented. Satisfies EU AI Act systemic risk controls (GPAISR) and credit spend governance.", "source": "BTWS-2027 AI Governance Report [REG-013]", "status": "implemented"}}, "prev_hash": "48685045d0a14037b2be722b17a2083d810eac6da17e00feb5523b4428ec395e", "hash": "b21f127afc6e23e91596046c96a7aa1a4ab2f57744ddb2bcbd4bbf4560a4cc37", "recursion_depth": 0}
{"seq": 753, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-219", "record": {"id": "REQ-219", "kind": "requirement", "status": "active", "label": "Local-First Model Routing for Governance Tasks", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-219", "title": "Local-First Model Routing for Governance Tasks", "description": "Governance classification tasks (preflight, verify, classify_intent) MUST default to a local Ollama model (zero cloud cost) and only escalate to cloud APIs when local confidence is below threshold. Reduces credit spend and avoids unnecessary data transfer to third parties.", "source": "BTWS-2027 AI Governance Report [REG-014]", "status": "implemented"}}, "prev_hash": "b21f127afc6e23e91596046c96a7aa1a4ab2f57744ddb2bcbd4bbf4560a4cc37", "hash": "3461c1105c8cc92de73db6fe3ec9475cbc1bd56dbdd7bcede96f4d0b0146124c", "recursion_depth": 0}
{"seq": 754, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-220", "record": {"id": "REQ-220", "kind": "requirement", "status": "active", "label": "Policy Guardrails at the Interface Layer", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-220", "title": "Policy Guardrails at the Interface Layer", "description": "specsmith MUST enforce allow/deny lists for tool categories and data access patterns at the agent interface layer — not just within prompts. Agents MUST NOT access live production databases or unmanaged data sources. Satisfies EU AI Act technical controls, California ADMT data governance requirements.", "source": "BTWS-2027 AI Governance Report [REG-015]", "status": "implemented"}}, "prev_hash": "3461c1105c8cc92de73db6fe3ec9475cbc1bd56dbdd7bcede96f4d0b0146124c", "hash": "b49dabb220ddba672c5f451b62f2b9866ab5bbb026faf316b7c3c7fe18c870c4", "recursion_depth": 0}
{"seq": 755, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-244", "record": {"id": "REQ-244", "kind": "requirement", "status": "active", "label": "GPU-Aware Context Window Sizing", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-244", "title": "GPU-Aware Context Window Sizing", "description": "Before starting an Ollama agent session, specsmith MUST detect available GPU VRAM (NVIDIA via nvidia-smi, AMD via rocm-smi) and recommend a num_ctx value. VRAM tiers: <6 GB → 4096, 6-12 GB → 8192, 12-20 GB → 16384, >=20 GB → 32768. CPU-only defaults to 4096. The function MUST never raise on any platform.", "source": "Plan 0ca40db4 [CTX-001]", "status": "implemented"}}, "prev_hash": "b49dabb220ddba672c5f451b62f2b9866ab5bbb026faf316b7c3c7fe18c870c4", "hash": "133d9f749021003ff869ddcd99e490454e31a2be39384802f31ffc1ee6625c4a", "recursion_depth": 0}
{"seq": 756, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-245", "record": {"id": "REQ-245", "kind": "requirement", "status": "active", "label": "Live Context Fill Indicator", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-245", "title": "Live Context Fill Indicator", "description": "Every active agent conversation MUST track and emit context fill events with schema: {type: context_fill, used: int, limit: int, pct: float}. The fill percentage MUST be surfaced in the terminal UI as a compact progress bar (green 0-60%, yellow 60-80%, orange 80-90%, red >90%).", "source": "Plan 0ca40db4 [CTX-002]", "status": "implemented"}}, "prev_hash": "133d9f749021003ff869ddcd99e490454e31a2be39384802f31ffc1ee6625c4a", "hash": "331d4d8f74f901d00d6d2077738408fae5262f582669ed7e5139347d2d5a5e90", "recursion_depth": 0}
{"seq": 757, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-246", "record": {"id": "REQ-246", "kind": "requirement", "status": "active", "label": "Auto Context Compression at Configurable Threshold", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-246", "title": "Auto Context Compression at Configurable Threshold", "description": "When context fill reaches the configurable compression threshold (default 80%, range 50-95%), specsmith MUST automatically trigger context summarization. Compression MUST emit a context_compressed event with before/after token counts. Auto-compression MUST be togglable; when off, only a warning is surfaced.", "source": "Plan 0ca40db4 [CTX-003]", "status": "implemented"}}, "prev_hash": "331d4d8f74f901d00d6d2077738408fae5262f582669ed7e5139347d2d5a5e90", "hash": "5e8ca3f881e970ef0923d7b850eee31afb39a1917a85ff1e9c8fb03a8e530990", "recursion_depth": 0}
{"seq": 758, "ts": "2026-05-17T12:36:43Z", "op": "upsert", "record_id": "REQ-247", "record": {"id": "REQ-247", "kind": "requirement", "status": "active", "label": "Hard Context Reservation — Never 100% Fill", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-247", "title": "Hard Context Reservation — Never 100% Fill", "description": "The context window MUST NEVER be allowed to reach 100% fill. A hard reservation of 15% (or MIN_FREE_TOKENS=2048, whichever is more restrictive) MUST remain free. When fill reaches the hard ceiling (default 85%), ContextFullError MUST be raised and emergency compression triggered regardless of the auto-compress toggle.", "source": "Plan 0ca40db4 [CTX-004]", "status": "implemented"}}, "prev_hash": "5e8ca3f881e970ef0923d7b850eee31afb39a1917a85ff1e9c8fb03a8e530990", "hash": "b710b4c6f2003829ca4ce9919be8b7da6c82b6bb74967098ef237470acd422ca", "recursion_depth": 0}
