{"seq": 669, "ts": "2026-06-25T03:32:12Z", "op": "upsert", "record_id": "TEST-375", "record": {"id": "TEST-375", "kind": "testcase", "status": "active", "label": "m007 migration converts markdown REQUIREMENTS.md and TESTS.md to YAML files, deletes them, and sets governance-mode=yaml; run_sync auto-triggers m007 for markdown-mode projects", "confidence": 1.0, "source_type": "observed", "evidence": ["synced from testcases.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "TEST-375", "version": 1, "title": "m007 migration converts markdown REQUIREMENTS.md and TESTS.md to YAML files, deletes them, and sets governance-mode=yaml; run_sync auto-triggers m007 for markdown-mode projects", "description": "", "requirement_id": "REQ-373", "type": "unit", "verification_method": "pytest tests/test_markdown_deprecation.py — create tmp project with REQUIREMENTS.md and TESTS.md but no YAML dirs, run m007, assert YAML files created, governance-mode=yaml written, MD files deleted; assert run_sync on markdown project triggers m007 automatically", "input": {}, "expected_behavior": {}, "confidence": 1.0}}, "prev_hash": "4124e84603049f6105292a4e67a154842299db4afde4f1faba4debd557322c48", "hash": "2cac5ca0f46c539fde507494785f3a268092a1011fc10c09b800e5d2f23167b9", "recursion_depth": 0}
