{"seq": 982, "ts": "2026-07-22T12:04:36Z", "op": "upsert", "record_id": "REQ-070", "record": {"id": "REQ-070", "kind": "requirement", "status": "active", "label": "Grace Must Normalize File Paths", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-070", "version": 1, "title": "Grace Must Normalize File Paths", "description": "All file paths supplied to Grace tools must be normalized to absolute, resolved paths before access.", "source": "ARCHITECTURE.md", "status": "implemented", "test_ids": ["TEST-070"]}}, "prev_hash": "044b235389476483a2e595083b29063a9ed9ba8284a21b5acdf66ebe60e7ce1f", "hash": "a2c942d312af9ec0105d956cb7f4bec5655381d997a02a04a722c29bc47252ca", "recursion_depth": 0}
{"seq": 983, "ts": "2026-07-22T12:04:36Z", "op": "upsert", "record_id": "REQ-423", "record": {"id": "REQ-423", "kind": "requirement", "status": "active", "label": "Governed benchmark claims must be statistically supported", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-423", "version": 1, "title": "Governed benchmark claims must be statistically supported", "description": "GovernanceBench MUST report observed pass rate, confidence intervals, token use, and global cost-of-pass without assuming a stochastic model achieves 100% correctness. Publication claims require complete comparable cells and enough repetitions to distinguish signal from sampling noise. A zero-pass task MUST remain in aggregate cost-of-pass rather than being silently excluded.", "source": "docs/requirements/", "status": "implemented", "test_ids": ["TEST-433"]}}, "prev_hash": "a2c942d312af9ec0105d956cb7f4bec5655381d997a02a04a722c29bc47252ca", "hash": "861232cb82b278970577d52acf091495533c7307cefde1acdcd8ed5974b8e558", "recursion_depth": 0}
{"seq": 984, "ts": "2026-07-22T12:04:36Z", "op": "upsert", "record_id": "REQ-425", "record": {"id": "REQ-425", "kind": "requirement", "status": "active", "label": "Deterministic benchmark governance must fail safely on unclear scope", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-425", "version": 1, "title": "Deterministic benchmark governance must fail safely on unclear scope", "description": "The benchmark harness MUST run governance outside the model token path against isolated task state. Accepted coding tasks receive only linked requirement, test, confidence, and uncertainty evidence. Ambiguous or destructive tasks MUST short-circuit safely on needs_clarification; the harness MUST never fabricate a requirement, bypass the decision, or prompt a model to implement anyway.", "source": "WI-B73B339B", "status": "implemented", "test_ids": ["TEST-435"]}}, "prev_hash": "861232cb82b278970577d52acf091495533c7307cefde1acdcd8ed5974b8e558", "hash": "435c97a1252b22f79b2b8788c2fd7997d2743dc8fa53bf06e2e322dca4d610a3", "recursion_depth": 0}
{"seq": 985, "ts": "2026-07-22T12:04:36Z", "op": "upsert", "record_id": "REQ-426", "record": {"id": "REQ-426", "kind": "requirement", "status": "active", "label": "Benchmark completion budgets must be bounded and model-compatible", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-426", "version": 1, "title": "Benchmark completion budgets must be bounded and model-compatible", "description": "The harness MUST use each provider's compatible completion-budget parameter, keep a bounded default sufficient for tool calls, cap agent turns and context, and allow explicit environment overrides for diagnostic runs. It MUST NOT grant an unconditional oversized output budget merely because a model can reason.", "source": "docs/requirements/", "status": "implemented", "test_ids": ["TEST-436"]}}, "prev_hash": "435c97a1252b22f79b2b8788c2fd7997d2743dc8fa53bf06e2e322dca4d610a3", "hash": "25c51c7fbf6635ebf11897ffb9c7ee66953f254709df4f7046f30740452a7c7e", "recursion_depth": 0}
{"seq": 986, "ts": "2026-07-22T12:04:36Z", "op": "upsert", "record_id": "REQ-457", "record": {"id": "REQ-457", "kind": "requirement", "status": "active", "label": "Zoo Code Local-LLM import profile lifecycle", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-457", "version": 1, "title": "Zoo Code Local-LLM import profile lifecycle", "description": "Specsmith MUST generate the current Zoo Code import document for a Local-LLM LiteLLM profile at http://127.0.0.1:4000; map built-in and discovered Specsmith modes to that profile; request prompt caching only when capability metadata confirms support; preserve user-owned profiles and mappings; repair only Specsmith-managed malformed, obsolete, or tampered assets with a backup; never serialize an API key; and generate portable Windows, Linux, and macOS auto-import configuration.", "source": "GitHub issue #331; Zoo Code upstream provider-settings and importExport schemas", "status": "implemented", "test_ids": ["TEST-481", "TEST-482", "TEST-483"]}}, "prev_hash": "25c51c7fbf6635ebf11897ffb9c7ee66953f254709df4f7046f30740452a7c7e", "hash": "396836849295283c564f6c7c40e526ea4041e4832c788b9a7983ac6ad94926e2", "recursion_depth": 0}
{"seq": 987, "ts": "2026-07-22T12:04:36Z", "op": "upsert", "record_id": "REQ-458", "record": {"id": "REQ-458", "kind": "requirement", "status": "active", "label": "Concurrent-safe MCP project registry", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-458", "version": 1, "title": "Concurrent-safe MCP project registry", "description": "Specsmith MUST atomically read-modify-write the persistent MCP project registry under a bounded process-safe lock so concurrent register, unregister, and prune operations preserve valid unrelated entries on Windows, Linux, and macOS without leaving a partial registry file or lock.", "source": "GitHub issue #316; MCPREG-007 and MCPREG-008", "status": "implemented", "test_ids": ["TEST-484"]}}, "prev_hash": "396836849295283c564f6c7c40e526ea4041e4832c788b9a7983ac6ad94926e2", "hash": "f06b8369c05cbeea00dbc72d15032d9bdf84f20f7f565fa464f1db1bdfa5b1e5", "recursion_depth": 0}
{"seq": 988, "ts": "2026-07-22T12:04:36Z", "op": "upsert", "record_id": "REQ-459", "record": {"id": "REQ-459", "kind": "requirement", "status": "active", "label": "Cross-platform wheel smoke validation", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-459", "version": 1, "title": "Cross-platform wheel smoke validation", "description": "Specsmith CI MUST build the candidate wheel and validate a clean wheel installation through public generic initialization, audit, strict validation, sync, fixed-point, and Zoo Code asset generation on Windows, Linux, and macOS using path names containing spaces and Unicode without shell activation or platform-specific console-script paths.", "source": "GitHub issue #330", "status": "implemented", "test_ids": ["TEST-485"]}}, "prev_hash": "f06b8369c05cbeea00dbc72d15032d9bdf84f20f7f565fa464f1db1bdfa5b1e5", "hash": "96f16b2c1b12efa2ad6a8ad89c6090e0c824075066410a7ce75e0f942b691cbc", "recursion_depth": 0}
{"seq": 989, "ts": "2026-07-22T12:04:36Z", "op": "upsert", "record_id": "REQ-460", "record": {"id": "REQ-460", "kind": "requirement", "status": "active", "label": "Permissive Zoo Code command default", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-460", "version": 1, "title": "Permissive Zoo Code command default", "description": "Specsmith MUST emit Zoo Code's current globalSettings.allowedCommands setting as exactly [\"*\"] in its managed settings-import asset for new projects; preserve user-owned assets and live user settings; migrate only an untouched, provenance-marked prior default; and document that this intentional permissive execution control is separate from Specsmith governance and unsuitable for untrusted repositories without user restriction.", "source": "GitHub issue #329; Zoo Code global-settings and auto-approval schemas", "status": "implemented", "test_ids": ["TEST-486"]}}, "prev_hash": "96f16b2c1b12efa2ad6a8ad89c6090e0c824075066410a7ce75e0f942b691cbc", "hash": "5608880bc6ffcaf5c743a9ff9f0e5e22837ca24e2584fe83ec5216e428320b68", "recursion_depth": 0}
