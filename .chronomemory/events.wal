{"seq": 269, "ts": "2026-06-15T15:19:56Z", "op": "upsert", "record_id": "REQ-311", "record": {"id": "REQ-311", "kind": "requirement", "status": "active", "label": "RAG Retrieval Must Filter by Confidence", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-311", "title": "RAG Retrieval Must Filter by Confidence", "description": "ESDB retrieval MUST accept a min_confidence threshold and exclude records with confidence < min_confidence. Records at exactly the threshold MUST be included. Default threshold is 0.0 (no filtering).", "source": "ARCHITECTURE.md §ESDB / ChronoStore", "status": "implemented", "test_ids": ["TEST-311"]}}, "prev_hash": "4ddb0076f7b06e430430b05db46d1647d94a2eb05440ffa49f560479d78f1e1c", "hash": "d0f5eb2006c31117727fe9146db00f42cecf887a58026b552835d636deebd161", "recursion_depth": 0}
