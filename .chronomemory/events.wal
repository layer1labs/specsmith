{"seq": 204, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-205", "record": {"id": "REQ-205", "kind": "requirement", "status": "defined", "label": "specsmith-ide Electron Desktop Packaging", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-205", "title": "specsmith-ide Electron Desktop Packaging", "description": "specsmith-ide MUST be packageable as an Electron desktop application.", "source": "docs/PLANNED-REQUIREMENTS.md (IDE-005)", "status": "defined"}}, "prev_hash": "b6cae596e8c3358f51c6a2bc1927800de72e984b128352ecf4a8e1778cc7adcc", "hash": "3ddcbdec4edd806324a6010cb30d421491b46b5c44a298d7dac17ca019fe7209", "recursion_depth": 0}
{"seq": 205, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-206", "record": {"id": "REQ-206", "kind": "requirement", "status": "defined", "label": "Tamper-Evident Agent Action Log", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-206", "title": "Tamper-Evident Agent Action Log", "description": "specsmith MUST maintain a tamper-evident, append-only agent action log capturing every governance decision, tool invocation, input, and output. The log chain MUST use SHA-256 chaining so any modification is detectable. Satisfies EU AI Act Art. 12 (logging obligations) and NIST AI RMF (GO-6).", "source": "BTWS-2027 AI Governance Report [REG-001]", "status": "defined"}}, "prev_hash": "3ddcbdec4edd806324a6010cb30d421491b46b5c44a298d7dac17ca019fe7209", "hash": "9891fcdc64aff66a1adc5aa74a5c72ff2a884f6b2ae012630a62f1498cfe1a68", "recursion_depth": 0}
{"seq": 206, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-207", "record": {"id": "REQ-207", "kind": "requirement", "status": "defined", "label": "Explanation Artifacts for Governance Decisions", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-207", "title": "Explanation Artifacts for Governance Decisions", "description": "Every governance decision (preflight, verify, classify) MUST produce an 'explanation artifact' recording: what data was used, which requirements were matched, why the decision was reached, and the confidence score. Satisfies EU AI Act Art. 13 (transparency), CFPB adverse-action requirements.", "source": "BTWS-2027 AI Governance Report [REG-002]", "status": "defined"}}, "prev_hash": "9891fcdc64aff66a1adc5aa74a5c72ff2a884f6b2ae012630a62f1498cfe1a68", "hash": "9dd8a737f870e521b173f6d2614c2565bd03a210534edb230239549699cfd40a", "recursion_depth": 0}
{"seq": 207, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-208", "record": {"id": "REQ-208", "kind": "requirement", "status": "defined", "label": "Action Log Replay and Export", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-208", "title": "Action Log Replay and Export", "description": "specsmith MUST support structured replay and export of agent action logs for external audit, regulatory submission, or incident investigation. Export format MUST be machine-readable (JSONL) and human-readable (Markdown). Satisfies OMB M-24-10 (AI use case inventories) and EU AI Act post-market monitoring.", "source": "BTWS-2027 AI Governance Report [REG-003]", "status": "defined"}}, "prev_hash": "9dd8a737f870e521b173f6d2614c2565bd03a210534edb230239549699cfd40a", "hash": "d38117bbe4dcf9830d5fe5ea0ad025be1583279f8456eababc118488b28774ba", "recursion_depth": 0}
{"seq": 208, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-209", "record": {"id": "REQ-209", "kind": "requirement", "status": "defined", "label": "Human Escalation Threshold", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-209", "title": "Human Escalation Threshold", "description": "specsmith MUST provide a configurable human-escalation threshold. When preflight confidence is below the threshold, or when a destructive/release intent is detected, execution MUST pause and route to human review. Satisfies NIST AI RMF (GO-4), OMB M-24-10 human-in-the-loop requirements.", "source": "BTWS-2027 AI Governance Report [REG-004]", "status": "defined"}}, "prev_hash": "d38117bbe4dcf9830d5fe5ea0ad025be1583279f8456eababc118488b28774ba", "hash": "bdbd84494e671bf1aa737935379d675e91f259ca092b7b85270ae6a7469b997f", "recursion_depth": 0}
{"seq": 209, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-210", "record": {"id": "REQ-210", "kind": "requirement", "status": "defined", "label": "Emergency Kill-Switch and Circuit-Breaker", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-210", "title": "Emergency Kill-Switch and Circuit-Breaker", "description": "specsmith MUST implement an emergency kill-switch that immediately halts agent activity when: (a) the user invokes a stop command, (b) an anomaly detector triggers, or (c) the retry budget is exhausted. The kill-switch MUST be reachable from both the CLI and the REST API. Satisfies EU AI Act Art. 14 (human oversight), NIST AI RMF.", "source": "BTWS-2027 AI Governance Report [REG-005]", "status": "defined"}}, "prev_hash": "bdbd84494e671bf1aa737935379d675e91f259ca092b7b85270ae6a7469b997f", "hash": "57ef1c517a5723a5f90daf32f25e7ef160fbdca90959abc2ef47bf05a1d66d66", "recursion_depth": 0}
{"seq": 210, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-211", "record": {"id": "REQ-211", "kind": "requirement", "status": "defined", "label": "Post-Market Behavioral Monitoring and Alerting", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-211", "title": "Post-Market Behavioral Monitoring and Alerting", "description": "specsmith MUST monitor agent behavior across sessions and alert when anomalous patterns are detected: unexpected confidence regression, unusual tool usage rates, or systematic requirement mismatches. Satisfies EU AI Act Art. 72 (post-market monitoring) and OMB M-24-10.", "source": "BTWS-2027 AI Governance Report [REG-006]", "status": "defined"}}, "prev_hash": "57ef1c517a5723a5f90daf32f25e7ef160fbdca90959abc2ef47bf05a1d66d66", "hash": "e9f1a5e21815b9ba2120a4950db011f23360216d9c749b5fcb80c233469d7c36", "recursion_depth": 0}
{"seq": 211, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-212", "record": {"id": "REQ-212", "kind": "requirement", "status": "defined", "label": "One-Click Rollback for File-Modifying Actions", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-212", "title": "One-Click Rollback for File-Modifying Actions", "description": "Every agent action that modifies governance files MUST create a timestamped backup before overwriting, and MUST expose a rollback command that restores the pre-action state. Satisfies NIST AI GenAI Profile (rollback and compensation), CFPB.", "source": "BTWS-2027 AI Governance Report [REG-007]", "status": "defined"}}, "prev_hash": "e9f1a5e21815b9ba2120a4950db011f23360216d9c749b5fcb80c233469d7c36", "hash": "731bde4a4f0a6f8fe19b71eda30bb8072b8c6214581a4b3202512d0f08999da0", "recursion_depth": 0}
{"seq": 212, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-213", "record": {"id": "REQ-213", "kind": "requirement", "status": "defined", "label": "Safe Append-Only Write for New Governance Entries", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-213", "title": "Safe Append-Only Write for New Governance Entries", "description": "All new entries appended to governance files (LEDGER.md, REQUIREMENTS.md, TESTS.md) MUST use append-only mode — never truncating or overwriting existing content. Protects against data loss from agent errors. Satisfies EU AI Act technical controls and data integrity requirements.", "source": "BTWS-2027 AI Governance Report [REG-008]", "status": "defined"}}, "prev_hash": "731bde4a4f0a6f8fe19b71eda30bb8072b8c6214581a4b3202512d0f08999da0", "hash": "a6fe62ce3cb554ec7f1ec527ad9bb6db2e857596638880c1436647c5f43ac72a", "recursion_depth": 0}
{"seq": 213, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-214", "record": {"id": "REQ-214", "kind": "requirement", "status": "defined", "label": "AI Disclosure Metadata in Agent Outputs", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-214", "title": "AI Disclosure Metadata in Agent Outputs", "description": "Outputs generated by specsmith agents MUST include AI disclosure metadata when surfaced to end-users: which model was used, provider, confidence level, and whether the output was governance-gated. Satisfies FTC Operation AI Comply, Utah SB149 (2024) disclosure requirements.", "source": "BTWS-2027 AI Governance Report [REG-009]", "status": "defined"}}, "prev_hash": "a6fe62ce3cb554ec7f1ec527ad9bb6db2e857596638880c1436647c5f43ac72a", "hash": "e2bf06b066ec17efab6c770b0843778e31605d4b49150f9fd4899eae8f9ffa4f", "recursion_depth": 0}
{"seq": 214, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-215", "record": {"id": "REQ-215", "kind": "requirement", "status": "defined", "label": "Regulatory Compliance Export Report", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-215", "title": "Regulatory Compliance Export Report", "description": "specsmith MUST generate a structured compliance export report covering: AI system inventory, risk classification, human oversight controls, audit log summary, and incident history. Satisfies OMB M-24-10, Colorado SB24-205 impact assessments, EU AI Act technical docs.", "source": "BTWS-2027 AI Governance Report [REG-010]", "status": "defined"}}, "prev_hash": "e2bf06b066ec17efab6c770b0843778e31605d4b49150f9fd4899eae8f9ffa4f", "hash": "9cca5539787650b4b99a92c639e18cfbc8d6d314a97038d879893be68bfaf400", "recursion_depth": 0}
{"seq": 215, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-216", "record": {"id": "REQ-216", "kind": "requirement", "status": "defined", "label": "Agent Risk Classification Before Deployment", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-216", "title": "Agent Risk Classification Before Deployment", "description": "Before activating a governance profile or agent session, specsmith MUST classify the intended use case against EU AI Act risk tiers (prohibited, high-risk Annex III, GPAI systemic-risk, or minimal-risk). High-risk use cases MUST require additional confirmation. Satisfies EU AI Act Art. 6 risk-based approach.", "source": "BTWS-2027 AI Governance Report [REG-011]", "status": "defined"}}, "prev_hash": "9cca5539787650b4b99a92c639e18cfbc8d6d314a97038d879893be68bfaf400", "hash": "8840d9914c059b8bd1cb6b49418312688438c90ed25ae3dab386b37c7bd79a84", "recursion_depth": 0}
{"seq": 216, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-217", "record": {"id": "REQ-217", "kind": "requirement", "status": "defined", "label": "Least-Privilege Agent Permissions", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-217", "title": "Least-Privilege Agent Permissions", "description": "Every agent session MUST operate with the minimum permissions required. Agent capabilities MUST be explicitly declared, and sensitive operations (commit, push, create PR, external calls) MUST be individually gated. Satisfies EU AI Act agent registration, NIST AI RMF least-privilege principle.", "source": "BTWS-2027 AI Governance Report [REG-012]", "status": "defined"}}, "prev_hash": "8840d9914c059b8bd1cb6b49418312688438c90ed25ae3dab386b37c7bd79a84", "hash": "b70323728c242cde00cb9c045228702e2824020c4b1bb02278b485c83c2dee34", "recursion_depth": 0}
{"seq": 217, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-218", "record": {"id": "REQ-218", "kind": "requirement", "status": "defined", "label": "Self-Optimization Bounded by Iteration Budget", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-218", "title": "Self-Optimization Bounded by Iteration Budget", "description": "All self-improvement loops (agent improve, eval harness, continuous learning) MUST be bounded by a configurable iteration budget. Unbounded recursion or runaway optimisation MUST be prevented. Satisfies EU AI Act systemic risk controls (GPAISR) and credit spend governance.", "source": "BTWS-2027 AI Governance Report [REG-013]", "status": "defined"}}, "prev_hash": "b70323728c242cde00cb9c045228702e2824020c4b1bb02278b485c83c2dee34", "hash": "9d89217f478c7710a3e994e5454fee99d35f981f1eba8341e8a7b3e17c4afa58", "recursion_depth": 0}
{"seq": 218, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-219", "record": {"id": "REQ-219", "kind": "requirement", "status": "defined", "label": "Local-First Model Routing for Governance Tasks", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-219", "title": "Local-First Model Routing for Governance Tasks", "description": "Governance classification tasks (preflight, verify, classify_intent) MUST default to a local Ollama model (zero cloud cost) and only escalate to cloud APIs when local confidence is below threshold. Reduces credit spend and avoids unnecessary data transfer to third parties.", "source": "BTWS-2027 AI Governance Report [REG-014]", "status": "defined"}}, "prev_hash": "9d89217f478c7710a3e994e5454fee99d35f981f1eba8341e8a7b3e17c4afa58", "hash": "ba33847e84bd4f52b6cd32f32c66de04dbcf651d37319c08504d133f5098977d", "recursion_depth": 0}
{"seq": 219, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-220", "record": {"id": "REQ-220", "kind": "requirement", "status": "defined", "label": "Policy Guardrails at the Interface Layer", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-220", "title": "Policy Guardrails at the Interface Layer", "description": "specsmith MUST enforce allow/deny lists for tool categories and data access patterns at the agent interface layer — not just within prompts. Agents MUST NOT access live production databases or unmanaged data sources. Satisfies EU AI Act technical controls, California ADMT data governance requirements.", "source": "BTWS-2027 AI Governance Report [REG-015]", "status": "defined"}}, "prev_hash": "ba33847e84bd4f52b6cd32f32c66de04dbcf651d37319c08504d133f5098977d", "hash": "cf589cb443d553755f7f5ad380f1ed3bf4558bea8657c64dfca9ee1772e53097", "recursion_depth": 0}
{"seq": 220, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-244", "record": {"id": "REQ-244", "kind": "requirement", "status": "defined", "label": "GPU-Aware Context Window Sizing", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-244", "title": "GPU-Aware Context Window Sizing", "description": "Before starting an Ollama agent session, specsmith MUST detect available GPU VRAM (NVIDIA via nvidia-smi, AMD via rocm-smi) and recommend a num_ctx value. VRAM tiers: <6 GB → 4096, 6-12 GB → 8192, 12-20 GB → 16384, >=20 GB → 32768. CPU-only defaults to 4096. The function MUST never raise on any platform.", "source": "Plan 0ca40db4 [CTX-001]", "status": "defined"}}, "prev_hash": "cf589cb443d553755f7f5ad380f1ed3bf4558bea8657c64dfca9ee1772e53097", "hash": "46aa362aec884d54153405719f4a1bb1bd4fe313d385c888f57811dc232408ca", "recursion_depth": 0}
{"seq": 221, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-245", "record": {"id": "REQ-245", "kind": "requirement", "status": "defined", "label": "Live Context Fill Indicator", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-245", "title": "Live Context Fill Indicator", "description": "Every active agent conversation MUST track and emit context fill events with schema: {type: context_fill, used: int, limit: int, pct: float}. The fill percentage MUST be surfaced in the terminal UI as a compact progress bar (green 0-60%, yellow 60-80%, orange 80-90%, red >90%).", "source": "Plan 0ca40db4 [CTX-002]", "status": "defined"}}, "prev_hash": "46aa362aec884d54153405719f4a1bb1bd4fe313d385c888f57811dc232408ca", "hash": "22ffde5f2296bf5aaee7220617417858c95c923143ae4217be50afbb2c4df8d1", "recursion_depth": 0}
{"seq": 222, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-246", "record": {"id": "REQ-246", "kind": "requirement", "status": "defined", "label": "Auto Context Compression at Configurable Threshold", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-246", "title": "Auto Context Compression at Configurable Threshold", "description": "When context fill reaches the configurable compression threshold (default 80%, range 50-95%), specsmith MUST automatically trigger context summarization. Compression MUST emit a context_compressed event with before/after token counts. Auto-compression MUST be togglable; when off, only a warning is surfaced.", "source": "Plan 0ca40db4 [CTX-003]", "status": "defined"}}, "prev_hash": "22ffde5f2296bf5aaee7220617417858c95c923143ae4217be50afbb2c4df8d1", "hash": "93d81bb417e1baede2e792b1214404d7e05b76784360525daafc8c1b3121a4a2", "recursion_depth": 0}
{"seq": 223, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-247", "record": {"id": "REQ-247", "kind": "requirement", "status": "defined", "label": "Hard Context Reservation — Never 100% Fill", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-247", "title": "Hard Context Reservation — Never 100% Fill", "description": "The context window MUST NEVER be allowed to reach 100% fill. A hard reservation of 15% (or MIN_FREE_TOKENS=2048, whichever is more restrictive) MUST remain free. When fill reaches the hard ceiling (default 85%), ContextFullError MUST be raised and emergency compression triggered regardless of the auto-compress toggle.", "source": "Plan 0ca40db4 [CTX-004]", "status": "defined"}}, "prev_hash": "93d81bb417e1baede2e792b1214404d7e05b76784360525daafc8c1b3121a4a2", "hash": "df40e0c73eaaa6e590893ae9959889f5c68d08e3112ff96679b5fdeed1396d80", "recursion_depth": 0}
{"seq": 224, "ts": "2026-05-17T11:41:09Z", "op": "upsert", "record_id": "REQ-248", "record": {"id": "REQ-248", "kind": "requirement", "status": "implemented", "label": "Dev/Stable Update Channel Persistence", "confidence": 0.7, "source_type": "observed", "evidence": ["migrated from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-248", "title": "Dev/Stable Update Channel Persistence", "description": "specsmith MUST persist a user-chosen update channel (stable or dev) to ~/.specsmith/channel. specsmith channel set {stable|dev} writes the file; channel clear removes it. effective_channel_with_source() MUST return (channel, source) where source is user when the file exists, otherwise", "source": "ARCHITECTURE.md [Update Channel Selection]", "status": "implemented"}}, "prev_hash": "df40e0c73eaaa6e590893ae9959889f5c68d08e3112ff96679b5fdeed1396d80", "hash": "54927d6dcbfd7730c32c6e8d0ddf1041afa2fec6fe58dddf71efce3658819494", "recursion_depth": 0}
