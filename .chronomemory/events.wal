{"seq": 611, "ts": "2026-05-17T12:36:40Z", "op": "upsert", "record_id": "REQ-076", "record": {"id": "REQ-076", "kind": "requirement", "status": "active", "label": "Nexus Tool Executor Registration Must Be Unique", "confidence": 0.7, "source_type": "observed", "evidence": ["synced from requirements.json"], "epistemic_boundary": [], "is_hypothesis": false, "model_assumptions": {}, "recursion_depth": 0, "data": {"id": "REQ-076", "title": "Nexus Tool Executor Registration Must Be Unique", "description": "Each Nexus tool must be registered with the AG2 executor exactly once; LLM-side tool signatures may be attached to multiple caller agents but the execution function must not be re-registered to avoid AG2 override warnings.", "source": "ARCHITECTURE.md", "status": "implemented"}}, "prev_hash": "cbe26eb72a054e09aee3e528ac1cd765421cce57b57a33373bf25ed54dea14fe", "hash": "7a1264ba0d0b26745b9fedc07bb5085d6e9f5c289de45e7862e3bb0cac76bd52", "recursion_depth": 0}
