{
	"mcpServers": {
		"specsmith-governance": {
			"command": "specsmith",
			"args": [
				"mcp",
				"serve",
				"--project-dir",
				"."
			],
			"env": {
				"SPECSMITH_ALLOW_NON_PIPX": "1",
				"SPECSMITH_NO_AUTO_UPDATE": "1",
				"SPECSMITH_PYPI_CHECKED": "1"
			},
			"alwaysAllow": [
				"governance_phase",
				"governance_req_list",
				"governance_audit",
				"governance_preflight",
				"governance_project_list",
				"governance_checkpoint",
				"governance_trace_seal"
			]
		}
	}
}