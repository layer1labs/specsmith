{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specsmith.dev/schemas/governancebench/leaderboard_schema.json",
  "title": "GovernanceBench HF Leaderboard Export",
  "description": "Schema for BenchReport.hf_leaderboard_json output.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/leaderboard_row"
  },
  "$defs": {
    "leaderboard_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "model",
        "scaffold",
        "task_suite",
        "pass_rate",
        "tokens_per_correct_answer",
        "cop_usd",
        "scaffold_lift",
        "model_tier"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "scaffold": {
          "type": "string",
          "minLength": 1
        },
        "task_suite": {
          "type": "string",
          "minLength": 1
        },
        "pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "tokens_per_correct_answer": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "cop_usd": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ],
          "description": "Estimated USD cost-of-pass; null when non-finite."
        },
        "scaffold_lift": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "model_tier": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
