{
    "name": "specsmith-vscode",
    "displayName": "Specsmith",
    "description": "Specsmith governance and compliance integration for Visual Studio Code",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:python",
        "workspaceContains:.specsmith/config.yml"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "specsmith.initializeProject",
                "title": "Specsmith: Initialize Project"
            },
            {
                "command": "specsmith.runAudit",
                "title": "Specsmith: Run Audit"
            },
            {
                "command": "specsmith.checkCompliance",
                "title": "Specsmith: Check Compliance"
            },
            {
                "command": "specsmith.analyzeCodeQuality",
                "title": "Specsmith: Analyze Code Quality"
            },
            {
                "command": "specsmith.viewComplianceReport",
                "title": "Specsmith: View Compliance Report"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "specsmith.initializeProject",
                    "when": "explorerResourceIsFolder"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "Specsmith",
            "properties": {
                "specsmith.complianceCheckOnSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable compliance checking on file save"
                },
                "specsmith.codeAnalysisEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable code analysis integration"
                },
                "specsmith.projectRoot": {
                    "type": "string",
                    "default": ".",
                    "description": "Project root directory"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.1",
        "@types/node": "16.x",
        "@typescript-eslint/eslint-plugin": "^5.59.11",
        "@typescript-eslint/parser": "^5.59.11",
        "eslint": "^8.42.0",
        "glob": "^8.1.0",
        "mocha": "^10.2.0",
        "typescript": "^5.1.6"
    },
    "dependencies": {
        "vscode-languageclient": "^8.0.2"
    }
}
